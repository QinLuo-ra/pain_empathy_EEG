%%各 Bin 独立达标过滤 (Bin5 >= 30 & Bin6 >= 30)
clear; clc;
data_path = 'D:\painempathy\data\TD_TF\ERP\8_epoch_test';
save_path = 'D:\painempathy\data\TD_TF\ERP\9_eject';
if ~exist(save_path, 'dir'), mkdir(save_path); end

cd(data_path);
files = dir('*.set');
fn = {files.name};
qa_report = table(); 

for i = 1:length(fn)
    fprintf('\n>>> 处理中 [%d/%d]: %s\n', i, length(fn), fn{i});
    
    % 1. 载入并彻底清理旧标记
    EEG = pop_loadset('filename', fn{i}, 'filepath', data_path);
    EEG.reject.rejmanual = [];
    EEG.reject.rejthresh = [];
    EEG = eeg_checkset(EEG);

 % 假设你的 Epoch 时间范围是 -200ms 到 800ms（请根据你真实的 epoch 设置修改）
% 如果想检查全时段，请务必写全 [start end]
EEG = pop_artextval(EEG, 'Channel', 1:EEG.nbchan, 'Flag', 1, ...
      'Threshold', [-150 150], 'Twindow', [EEG.xmin*1000 EEG.xmax*1000]);
    
    % --- 【核心逻辑修正：按 Bin 预计算】 ---
    % 获取当前所有 trials 的 bin 归属情况
    % 注意：pop_artextval 标记的是 trial 索引，我们要看哪些 trial 没被标记
    current_rej = EEG.reject.rejmanual; 
    keep_idx = find(current_rej == 0); % 没被标记为坏段的索引
    
    % 提取幸存 trial 的 Bin 编号
    survived_bins = [EEG.event(keep_idx).bini]; 
    
    % 分别统计 Bin 5 和 Bin 6 的幸存数量
    n_bin5 = sum(survived_bins == 5);
    n_bin6 = sum(survived_bins == 6);
    survived_total = length(keep_idx);

    % 3. 【严苛拦截】必须 bin5 >= 30 且 bin6 >= 30
    if n_bin5 >=10 && n_bin6 >=10
        try
            % 4. 物理剔除
            EEG = pop_rejepoch(EEG, current_rej, 0); 
            
            % 5. 记录 QA
            newRow = table({fn{i}}, n_bin5, n_bin6, survived_total, ...
                     'VariableNames', {'ID','Neutral_Bin5','Pain_Bin6','Total_Survived'});
            qa_report = [qa_report; newRow];
            
            % 6. 保存达标数据
            setname = [fn{i}(1:end-4), '_final.set'];
            pop_saveset(EEG, 'filename', setname, 'filepath', save_path);
            fprintf('  ✅ [达标] Bin5:%d, Bin6:%d. 已保存。\n', n_bin5, n_bin6);
            
        catch ME
            fprintf('  ❌ [运行时错误] %s: %s\n', fn{i}, ME.message);
        end
    else
        % 不达标直接跳过
        fprintf('  ⚠️ [拦截剔除] %s: 试次不足 (Bin5:%d, Bin6:%d)，已跳过。\n', ...
            fn{i}, n_bin5, n_bin6);
    end
end

writetable(qa_report, fullfile(save_path, 'Cleaning_Report_Strict.csv'));
fprintf('\n--- 严苛清洗完毕！请检查 9_eject 文件夹。 ---\n');
