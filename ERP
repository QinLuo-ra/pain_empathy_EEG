%% =========================================================================
%   ERP MODULE 3: Individual Difference Waves (Independent Storage)
%   逻辑：1. 读取平均波形 | 2. 计算 Bin 7 (P-N) | 3. 存入新文件夹 9ERP_DIF
% =========================================================================
clear; clc; 

% --- 1. 环境初始化 ---
eeglab_path = 'E:\eeglab2023.0'; 
if ~exist('pop_loadset', 'file'), addpath(eeglab_path); eeglab; end

% --- 2. 路径定义 ---
base_path = 'D:\painempathy\data\TD_TF\ERP';
path_in   = fullfile(base_path, '10ERP_AVG'); 
path_out  = fullfile(base_path, '11ERP_DIF'); 

if ~exist(path_out, 'dir'), mkdir(path_out); end

% --- 3. 获取文件列表 ---
files = dir(fullfile(path_in, '*.erp'));
if isempty(files)
    error('在路径 %s 中未找到 .erp 文件！', path_in);
end

fprintf('>>> 正在生成差异波并存入 %s...\n', path_out);

% --- 4. 循环处理 ---
for i = 1:length(files)
    try
        % A. 加载个体 ERP 文件
        ERP = pop_loaderp('filename', files(i).name, 'filepath', path_in);
        
        % B. 使用 Bin Operator 计算差异波
        % Bin 6 (3pain) - Bin 5 (3nopain)
        ERP = pop_binoperator(ERP, {'bin7 = bin6 - bin5 label Pain_Minus_Neutral'});
        
        % C. 保存到新文件夹 (保持原文件名)
        outName = files(i).name; 
        ERP = pop_savemyerp(ERP, 'erpname', [ERP.erpname, '_DIF'], 'filename', outName, ...
            'filepath', path_out, 'Warning', 'off');
            
        fprintf('  [成功] %s 已处理并存入 9ERP_DIF\n', outName);
        
    catch ME
        fprintf('  [失败] %s: %s\n', files(i).name, ME.message);
    end
end

fprintf('\n--- 差异波提取完成！共处理 %d 个文件。 ---\n', length(files));
